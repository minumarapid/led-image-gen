{
  "name": "led-image-gen-webfront",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:vite dev:wasm",
    "dev:vite": "vite",
    "dev:wasm": "nodemon --watch ../ --ext go --exec 'npm run build:wasm'",
    "build": "tsc -b && vite build",
    "build:wasm": "cd .. && go tool task build-wasm",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/m-plus-2": "^5.2.9",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "lucide-solid": "^1.14.0",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12"
  },
  "packageManager": "pnpm@11.0.1"
}
